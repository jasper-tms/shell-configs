#!/bin/bash

if [ -d ~/repos ]; then
    repos_dir=~/repos
elif [ -d /workspace/repos ]; then
    repos_dir=/workspace/repos
else
    echo "No repos directory found at ~/repos or /workspace/repos" >&2
    exit 1
fi

for repo in "$repos_dir"/*/.git "$repos_dir"/*/*/.git; do
    if [ ! -d "$repo" ]; then continue; fi
    cd ${repo%%.git}

    porcelain=$(git status --porcelain=v2 --branch 2>/dev/null)
    changes=$(echo "$porcelain" | grep -v '^#' | grep -v '^$')
    ahead_behind=$(echo "$porcelain" | awk '/^# branch.ab/ {print $3, $4}')

    if [ -z "$changes" ] && [ "$ahead_behind" = "+0 -0" ]; then
        continue
    fi

    echo $repo
    git status
    echo
done
