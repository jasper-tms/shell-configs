#!/usr/bin/env python3
"""
Regenerate the auto-generated `[tool.uv.sources]` block in a project's
`pyproject.toml`, pointing any dependency whose name matches an entry in
`~/.config/uv/local-packages.toml` at that local, editable clone.

This block is never meant to reach a commit: the global git filter
`uv-sources` (see `git config --global filter.uv-sources.*`) strips it out
again before content is staged. This script is what re-adds it to the
working tree, either by hand or from the `post-checkout`/`post-merge`/
`post-commit` hooks in this repository's `git-hooks/` directory.

Usage
-----
refresh-uv-editables [path/to/pyproject.toml]
    Rewrite the given file (or the current repository's pyproject.toml,
    found via `git rev-parse --show-toplevel`, if no path is given) in
    place.

refresh-uv-editables --clean
    Read a full file's content from standard input, strip the
    auto-generated block, and write the result to standard output. Used as
    the global git `clean` filter for `pyproject.toml` - do not run this
    by hand.

refresh-uv-editables --smudge
    Read a full file's content from standard input, inject the
    auto-generated block, and write the result to standard output. Used as
    the global git `smudge` filter for `pyproject.toml` - do not run this
    by hand.

refresh-uv-editables --register [path/to/repo]
    Add or update an entry in the registry for the given repository (or the
    current one, if no path is given): `name = "path"`, where `name` is
    read from that repository's own `[project.name]`. Unconditional -
    registers regardless of whose repo it is.

refresh-uv-editables --fresh-clone [path/to/repo]
    Like `--register`, but only writes to the registry if the repository's
    `origin` remote belongs to one of the accounts/organizations listed
    under `personal-remotes` in the registry file; otherwise just prints
    the equivalent `--register` command as a suggestion. Used by the
    `post-checkout` hook right after a fresh clone - do not run this by
    hand for other repos' sake, use `--register`.
"""
import re
import subprocess
import sys
import tomllib
from pathlib import Path

REGISTRY_PATH = Path.home() / '.config' / 'uv' / 'local-packages.toml'
BEGIN_MARKER = '# BEGIN uv-local-sources (auto-generated by refresh-uv-editables, do not edit or commit)'
END_MARKER = '# END uv-local-sources'
BLOCK_PATTERN = re.compile(re.escape(BEGIN_MARKER) + r'.*?' + re.escape(END_MARKER) + r'\n?',
                           re.DOTALL)
NAME_PATTERN = re.compile(r'[A-Za-z0-9_.-]+')


def normalize(name: str) -> str:
    """
    Normalize a distribution name the way PyPI does, so registry keys and
    names parsed out of `pyproject.toml` compare equal regardless of
    hyphen/underscore/case differences.

    Parameters
    ----------
    name : str
        A distribution name, e.g. from a dependency specifier or from
        `local-packages.toml`.

    Returns
    -------
    str
        The normalized name.
    """
    return name.lower().replace('_', '-')


def expand_path(path: str) -> str:
    """
    Expand a leading `~` (or `~user`) in `path` to an absolute path.

    Parameters
    ----------
    path : str
        A path, possibly `~`-prefixed, as stored in the registry file.

    Returns
    -------
    str
        The expanded, absolute path.
    """
    return str(Path(path).expanduser())


def contract_home(path: str) -> str:
    """
    Replace a leading home-directory prefix in `path` with `~`, so entries
    written to the registry file are portable across machines with
    different home directories.

    Parameters
    ----------
    path : str
        An absolute path.

    Returns
    -------
    str
        `path` with the home directory replaced by `~`, if `path` is under
        the home directory; otherwise `path` unchanged.
    """
    home = str(Path.home())
    if path == home:
        return '~'
    if path.startswith(home + '/'):
        return '~' + path[len(home):]
    return path


def load_registry() -> dict[str, str]:
    """
    Load the personal local-package registry.

    Returns
    -------
    dict[str, str]
        Mapping from distribution name to local clone path, expanded to an
        absolute path (see `expand_path()`), as declared under `[packages]`.
        Empty if the registry file does not exist yet.
    """
    if not REGISTRY_PATH.exists():
        return {}
    with open(REGISTRY_PATH, 'rb') as registry_file:
        packages = tomllib.load(registry_file).get('packages', {})
    return {name: expand_path(path) for name, path in packages.items()}


def load_personal_remotes() -> list[str]:
    """
    Load the configured list of GitHub accounts/organizations that count as
    your own, for auto-registration on a fresh clone.

    Returns
    -------
    list[str]
        Account/organization names, as declared under `personal-remotes` in
        the registry file. Empty if the registry file does not exist yet or
        declares none.
    """
    if not REGISTRY_PATH.exists():
        return []
    with open(REGISTRY_PATH, 'rb') as registry_file:
        return tomllib.load(registry_file).get('personal-remotes', [])


def strip_block(content: str) -> str:
    """
    Remove the auto-generated `[tool.uv.sources]` block from `content`, if
    present.

    Parameters
    ----------
    content : str
        The full text of a `pyproject.toml` file.

    Returns
    -------
    str
        `content` with the auto-generated block removed.
    """
    return BLOCK_PATTERN.sub('', content)


def dependency_names(content: str) -> set[str]:
    """
    Collect the normalized names of every dependency declared in
    `content`, across `[project.dependencies]`,
    `[project.optional-dependencies]`, and `[dependency-groups]`.

    Parameters
    ----------
    content : str
        The full text of a `pyproject.toml` file, with no auto-generated
        block present (an unparseable `[tool.uv.sources]` left over from a
        stale block would otherwise break parsing).

    Returns
    -------
    set[str]
        Normalized dependency names. Empty if `content` is not valid TOML.
    """
    try:
        data = tomllib.loads(content)
    except tomllib.TOMLDecodeError:
        return set()
    project = data.get('project', {})
    specifiers = list(project.get('dependencies', []))
    for group_specifiers in project.get('optional-dependencies', {}).values():
        specifiers.extend(group_specifiers)
    for group_specifiers in data.get('dependency-groups', {}).values():
        specifiers.extend(entry for entry in group_specifiers if isinstance(entry, str))
    names = set()
    for specifier in specifiers:
        match = NAME_PATTERN.match(specifier.strip())
        if match:
            names.add(normalize(match.group()))
    return names


def build_block(content: str, registry: dict[str, str]) -> str:
    """
    Build the auto-generated `[tool.uv.sources]` block for `content`, given
    the personal local-package registry.

    Parameters
    ----------
    content : str
        The full text of a `pyproject.toml` file, with no auto-generated
        block present.
    registry : dict[str, str]
        Mapping from distribution name to local clone path, as returned by
        `load_registry()`.

    Returns
    -------
    str
        The block text (including markers), or an empty string if none of
        `content`'s dependencies match the registry.
    """
    declared_names = dependency_names(content)
    matches = {name: path for name, path in registry.items()
               if normalize(name) in declared_names}
    if not matches:
        return ''
    lines = [BEGIN_MARKER, '[tool.uv.sources]']
    for name, path in sorted(matches.items()):
        lines.append(f'{name} = {{ path = "{path}", editable = true }}')
    lines.append(END_MARKER)
    return '\n'.join(lines) + '\n'


def inject_block(content: str, registry: dict[str, str]) -> str:
    """
    Return `content` with a fresh auto-generated `[tool.uv.sources]` block
    appended, replacing any existing one.

    Parameters
    ----------
    content : str
        The full text of a `pyproject.toml` file.
    registry : dict[str, str]
        Mapping from distribution name to local clone path, as returned by
        `load_registry()`.

    Returns
    -------
    str
        The updated file content.
    """
    cleaned = strip_block(content)
    block = build_block(cleaned, registry)
    if not block:
        return cleaned
    if not cleaned.endswith('\n'):
        cleaned += '\n'
    return cleaned + '\n' + block


def project_name(pyproject_path: Path) -> str | None:
    """
    Read the static `[project.name]` declared in a `pyproject.toml`.

    Parameters
    ----------
    pyproject_path : Path
        Path to the `pyproject.toml` file.

    Returns
    -------
    str or None
        The declared name, or `None` if the file is unparseable or declares
        no static name (e.g. a dynamic name from setuptools-scm or a
        `setup.py`-based project not yet migrated to PEP 621).
    """
    try:
        with open(pyproject_path, 'rb') as pyproject_file:
            data = tomllib.load(pyproject_file)
    except (tomllib.TOMLDecodeError, OSError):
        return None
    return data.get('project', {}).get('name')


def is_personal_remote(repo_path: Path, personal_remotes: list[str]) -> bool:
    """
    Check whether `repo_path`'s `origin` remote belongs to one of the given
    GitHub accounts/organizations.

    Parameters
    ----------
    repo_path : Path
        Path to a git repository.
    personal_remotes : list[str]
        Account/organization names (assumed to be under `github.com`), as
        returned by `load_personal_remotes()`.

    Returns
    -------
    bool
        `True` if `origin` is configured and matches one of
        `personal_remotes`.
    """
    try:
        result = subprocess.run(['git', '-C', str(repo_path), 'remote', 'get-url', 'origin'],
                                 capture_output=True, text=True, check=True)
    except (subprocess.CalledProcessError, FileNotFoundError):
        return False
    url = result.stdout.strip()
    patterns = [re.compile(rf'github\.com[:/]{re.escape(account)}/', re.IGNORECASE)
                for account in personal_remotes]
    return any(pattern.search(url) for pattern in patterns)


def register_entry(name: str, path: str) -> str:
    """
    Add or update `name = "path"` in the registry file.

    Parameters
    ----------
    name : str
        The distribution name to register.
    path : str
        The absolute path to the local clone. Stored with the home
        directory contracted to `~` (see `contract_home()`), so the
        registry file stays portable across machines with a different home
        directory.

    Returns
    -------
    str
        A human-readable message describing what happened, suitable for
        printing to the user.
    """
    path = contract_home(path)
    REGISTRY_PATH.parent.mkdir(parents=True, exist_ok=True)
    if REGISTRY_PATH.exists():
        lines = REGISTRY_PATH.read_text().splitlines(keepends=True)
    else:
        lines = ['personal-remotes = []\n', '\n', '[packages]\n']
    key_pattern = re.compile(r'^' + re.escape(name) + r'\s*=')
    new_line = f'{name} = "{path}"\n'
    for index, line in enumerate(lines):
        if key_pattern.match(line):
            if line.strip() == new_line.strip():
                return f'{name} is already registered at {path}'
            lines[index] = new_line
            REGISTRY_PATH.write_text(''.join(lines))
            return f'updated {name} -> {path}'
    if lines and not lines[-1].endswith('\n'):
        lines[-1] += '\n'
    lines.append(new_line)
    REGISTRY_PATH.write_text(''.join(lines))
    return f'registered {name} -> {path}'


def handle_repo(repo_path: Path, only_if_personal: bool, personal_remotes: list[str] = ()) -> None:
    """
    Register `repo_path` in the local-package registry, if it is a Python
    project with a static name.

    Parameters
    ----------
    repo_path : Path
        Path to a git repository.
    only_if_personal : bool
        If `True`, only write to the registry when `repo_path`'s `origin`
        belongs to one of `personal_remotes` (`is_personal_remote()`);
        otherwise just print the equivalent `--register` command as a
        suggestion. If `False`, always register, and `personal_remotes` is
        ignored.
    personal_remotes : list[str], optional
        Account/organization names to treat as your own, as returned by
        `load_personal_remotes()`. Only consulted when `only_if_personal`
        is `True`.

    Returns
    -------
    None
    """
    pyproject_path = repo_path / 'pyproject.toml'
    if not pyproject_path.exists():
        return
    name = project_name(pyproject_path)
    if not name:
        print(f'refresh-uv-editables: {repo_path} looks like a Python project but declares no '
              f'static [project.name] (dynamic name/version?) - not registering', file=sys.stderr)
        return
    if not only_if_personal or is_personal_remote(repo_path, personal_remotes):
        print(f'refresh-uv-editables: {register_entry(name, str(repo_path))}', file=sys.stderr)
    else:
        print(f"refresh-uv-editables: cloned '{name}' ({repo_path}) does not look like one of "
              f'your own repos - if you want it editable-linked everywhere, run:\n'
              f'  refresh-uv-editables --register {repo_path}', file=sys.stderr)


def find_pyproject() -> Path | None:
    """
    Locate the current repository's `pyproject.toml`.

    Returns
    -------
    Path or None
        The path to the repository root's `pyproject.toml`, or `None` if
        there is no enclosing git repository or it has no such file.
    """
    try:
        result = subprocess.run(['git', 'rev-parse', '--show-toplevel'],
                                 capture_output=True, text=True, check=True)
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None
    candidate = Path(result.stdout.strip()) / 'pyproject.toml'
    return candidate if candidate.exists() else None


def main() -> None:
    """
    Entry point.

    Returns
    -------
    None
    """
    registry = load_registry()

    if '--clean' in sys.argv:
        sys.stdout.write(strip_block(sys.stdin.read()))
        return

    if '--smudge' in sys.argv:
        sys.stdout.write(inject_block(sys.stdin.read(), registry))
        return

    if '--register' in sys.argv:
        index = sys.argv.index('--register')
        repo_path = Path(sys.argv[index + 1]) if len(sys.argv) > index + 1 else Path.cwd()
        handle_repo(repo_path.resolve(), only_if_personal=False)
        return

    if '--fresh-clone' in sys.argv:
        index = sys.argv.index('--fresh-clone')
        repo_path = Path(sys.argv[index + 1]) if len(sys.argv) > index + 1 else Path.cwd()
        handle_repo(repo_path.resolve(), only_if_personal=True,
                    personal_remotes=load_personal_remotes())
        return

    target = Path(sys.argv[1]) if len(sys.argv) > 1 else find_pyproject()
    if target is None or not target.exists():
        print('refresh-uv-editables: no pyproject.toml found', file=sys.stderr)
        sys.exit(1)

    original = target.read_text()
    updated = inject_block(original, registry)
    if updated != original:
        target.write_text(updated)
        print(f'refresh-uv-editables: updated {target}')
    else:
        print(f'refresh-uv-editables: no changes needed for {target}')


if __name__ == '__main__':
    main()
