#!/bin/bash
# Global git hook (see: git config --global core.hooksPath).
# On a fresh clone (previous HEAD is all zeros), registers the repo in the
# local-packages registry if it's one of your own (jasper-tms/NeLy-EPFL).
# Always refreshes the auto-generated [tool.uv.sources] block, then chains
# to any repo-local post-checkout hook a tool like pre-commit/husky may have
# installed directly into .git/hooks (which core.hooksPath would otherwise
# shadow).
set -e

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0

if [ "$1" = "0000000000000000000000000000000000000000" ]; then
    refresh-uv-editables --fresh-clone "$repo_root" || true
fi

if [ -f "$repo_root/pyproject.toml" ]; then
    refresh-uv-editables "$repo_root/pyproject.toml" || true
fi

local_hook="$(git rev-parse --git-dir)/hooks/post-checkout"
if [ -x "$local_hook" ]; then
    exec "$local_hook" "$@"
fi
